# ALBA data_IA — Variables de entorno
# Copia este archivo como .env y rellena tus claves.
# NUNCA subas el archivo .env a git (ya está en .gitignore).

# ── Groq (https://console.groq.com) ──────────────────────────────────────
GROQ_API_KEY=gsk_tu_api_key_aqui

# ── HuggingFace / ALIA Kit (Salamandra-7B BSC) ───────────────────────────
# Token en: https://huggingface.co/settings/tokens
HF_API_KEY=hf_tu_token_aqui

# ── DeepSeek (opcional, fallback) ────────────────────────────────────────
DEEPSEEK_API_KEY=sk_tu_key_deepseek

# ── Seguridad ─────────────────────────────────────────────────────────────
# Genera un secreto seguro: python3 -c "import secrets; print(secrets.token_hex(32))"
HMAC_SECRET=cambia-esto-en-produccion-minimo-32-chars-aleatorios

# ── GIS ICV (Institut Cartogràfic Valencià) ─────────────────────────────
# Servicios OGC verificados (acceso público, sin autenticación)
ICV_WMS_URL=http://terramapas.icv.gva.es/0105_Delimitaciones
ICV_WFS_URL=http://terramapas.icv.gva.es/0105_Delimitaciones
ICV_WMTS_URL=
GIS_TIMEOUT_SECONDS=15
